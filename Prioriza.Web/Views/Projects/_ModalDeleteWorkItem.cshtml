@model Prioriza.Web.Data.Entities.WorkItem

@{
    var projectId = (int)ViewData["projectId"]!;
}

<div class="modal fade" id="modalBorrarTarea-@Model.Id" tabindex="-1"
     aria-labelledby="modalBorrarTareaLabel-@Model.Id" aria-modal="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h5" id="modalBorrarTareaLabel-@Model.Id">¿Eliminar tarea?</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal"
                        aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                ¿Seguro que quieres eliminar <strong>@Model.Title</strong>?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm"
                        data-bs-dismiss="modal">Cancelar
                </button>
                <form asp-controller="WorkItems" asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id"/>
                    <input type="hidden" name="projectId" value="@projectId"/>
                    <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>
@model IEnumerable<Prioriza.Web.Data.Entities.Project>

@{
    ViewBag.Title = "Dashboard";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Mis proyectos</h1>
    <div class="d-flex gap-2">
        <button class="btn btn-secondary"
                data-bs-toggle="modal" data-bs-target="#modalCrearTarea">
            + Nueva tarea
        </button>
        <button class="btn btn-primary"
                data-bs-toggle="modal" data-bs-target="#modalCrearProyecto">
            + Nuevo proyecto
        </button>
    </div>
</div>

<!-- Buscador de proyectos -->
<div class="mb-4">
    <label for="filtroProyecto" class="visually-hidden">Buscar proyecto</label>
    <input type="search" id="filtroProyecto" class="form-control"
           placeholder="Buscar proyecto..." />
</div>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <p class="fs-5">Aún no tienes proyectos.</p>
        <button class="btn btn-primary"
                data-bs-toggle="modal" data-bs-target="#modalCrearProyecto">
            Crear tu primer proyecto
        </button>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var project in Model)
        {
            <div class="col project-item" data-nombre="@project.Name.ToLower()">
                <a asp-controller="Projects" asp-action="Details" asp-route-id="@project.Id"
                   class="text-decoration-none">
                    <div class="card h-100 shadow-sm project-card @(project.IsInbox ? "border-primary" : "")">
                        <div class="card-body">
                            <h2 class="card-title h5">
                                @if (project.IsInbox)
                                {
                                    <span class="me-1" aria-hidden="true">📥</span>
                                }
                                @project.Name
                            </h2>
                            <span class="badge bg-secondary mt-1">
                                @project.TareasPendientes pendiente@(project.TareasPendientes != 1 ? "s" : "")
                            </span>
                            <br/>
                            @if (!string.IsNullOrEmpty(project.Description))
                            {
                                <p class="card-text text-muted small">@project.Description</p>
                            }
                        </div>
                        <div class="card-footer bg-transparent">
                            <div class="d-flex justify-content-between small text-muted mb-1">
                                <span>Progreso</span>
                                <span>@project.Progreso%</span>
                            </div>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar" role="progressbar"
                                     style="width: @project.Progreso%"
                                     aria-valuenow="@project.Progreso"
                                     aria-valuemin="0" aria-valuemax="100"
                                     aria-label="Progreso: @project.Progreso%">
                                </div>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}

<!-- Modal: Crear proyecto -->
<div class="modal fade" id="modalCrearProyecto" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Projects" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h2 class="modal-title h5" id="modalCrearProyectoLabel">Nuevo proyecto</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"
                            aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="proyectoNombre" class="form-label">
                            Nombre <span class="text-danger" aria-hidden="true">*</span>
                            <span class="visually-hidden">(obligatorio)</span>
                        </label>
                        <input id="proyectoNombre" name="Name" class="form-control"
                               required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label for="proyectoDescripcion" class="form-label">Descripción</label>
                        <textarea id="proyectoDescripcion" name="Description"
                                  class="form-control" rows="3" maxlength="200"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Crear proyecto</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Crear tarea rápida hacia Inbox -->
<div class="modal fade" id="modalCrearTarea" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="WorkItems" asp-action="Create"
                  asp-route-projectId="@ViewBag.InboxId" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h2 class="modal-title h5" id="modalCrearTareaLabel">Nueva tarea</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"
                            aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    @if (ViewBag.InboxId == null)
                    {
                        <div class="alert alert-warning small" role="alert">
                            No se encontró el Inbox. Regístrate de nuevo o contacta soporte.
                        </div>
                    }
                    <div class="mb-3">
                        <label for="tareaTitulo" class="form-label">
                            Título <span class="text-danger" aria-hidden="true">*</span>
                            <span class="visually-hidden">(obligatorio)</span>
                        </label>
                        <input id="tareaTitulo" name="Title" class="form-control"
                               required maxlength="200" />
                    </div>
                    <div class="mb-3">
                        <label for="tareaDescripcion" class="form-label">Descripción</label>
                        <textarea id="tareaDescripcion" name="Description"
                                  class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="tareaPrioridad" class="form-label">Prioridad</label>
                        <select id="tareaPrioridad" name="Priority" class="form-select">
                            <option value="">Sin prioridad</option>
                            <option value="Baja">Baja</option>
                            <option value="Media">Media</option>
                            <option value="Alta">Alta</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="tareaFecha" class="form-label">Fecha límite</label>
                        <input id="tareaFecha" name="DueDate" type="date"
                               class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary"
                            @(ViewBag.InboxId == null ? "disabled" : "")>
                        Crear tarea
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('filtroProyecto').addEventListener('input', function () {
            const texto = this.value.toLowerCase();
            document.querySelectorAll('.project-item').forEach(item => {
                item.style.display = !texto || item.dataset.nombre.includes(texto)
                    ? '' : 'none';
            });
        });
    </script>
}
@using Prioriza.Web.Data.Entities
@model Prioriza.Web.Data.Entities.Project

@{
    ViewBag.Title = Model.Name;
    Layout = "_Layout";
    
    var pendientes = Model.Tasks.Where(t => !t.IsCompleted).ToList();
    var completadas = Model.Tasks.Where(t => t.IsCompleted).ToList();
}

<!-- Cabecera -->
<div class="d-flex justify-content-between align-items-start mb-2">
    <div>
        <a asp-controller="Projects" asp-action="Index"
           class="text-muted small text-decoration-none">
            ← Volver a proyectos
        </a>
        <h1 class="h3 mt-1 mb-0">@Model.Name</h1>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-muted mt-1 mb-0">@Model.Description</p>
        }
    </div>
    @if (!Model.IsInbox)
    {
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-secondary"
                    data-bs-toggle="modal" data-bs-target="#modalEditarProyecto">
                Editar
            </button>
            <button class="btn btn-sm btn-outline-danger"
                    data-bs-toggle="modal" data-bs-target="#modalBorrarProyecto">
                Eliminar
            </button>
        </div>
    }
</div>

<!-- Barra de progreso -->
<div class="my-4">
    <div class="d-flex justify-content-between small text-muted mb-1">
        <span>
            @Model.TareasPendientes
            tarea@(Model.TareasPendientes != 1 ? "s" : "") pendiente@(Model.TareasPendientes != 1 ? "s" : "")
        </span>
        <span>@Model.Progreso%</span>
    </div>
    <div class="progress" style="height: 8px;">
        <div class="progress-bar" role="progressbar"
             style="width: @Model.Progreso%"
             aria-valuenow="@Model.Progreso"
             aria-valuemin="0" aria-valuemax="100"
             aria-label="Progreso: @Model.Progreso%">
        </div>
    </div>
</div>

<!-- Matriz de Eisenhower -->
<ul class="nav nav-tabs mb-3" id="vistaTab">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab"
                data-bs-target="#vistaLista">
            Lista
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab"
                data-bs-target="#vistaMatriz">
            Matriz de Eisenhower
        </button>
    </li>
</ul>

<div class="tab-content">
    <div class="tab-pane fade show active" id="vistaLista">
        <!-- Aquí va todo el contenido actual: filtro, tarjetas pendientes, completadas -->
    </div>

    <div class="tab-pane fade" id="vistaMatriz">
        <div class="row g-3">

            <!-- Cuadrante 1: Importante + Urgente -->
            <div class="col-md-6">
                <div class="card border-danger h-100">
                    <div class="card-header bg-danger text-white fw-bold">
                        🔥 Hazlo ahora
                        <small class="fw-normal ms-1">Importante + Urgente</small>
                    </div>
                    <div class="card-body p-2">
                        @foreach (var task in pendientes.Where(t => t.EisenhowerQuadrant == EisenhowerQuadrant.DoFirst))
                        {
                            <div class="p-2 mb-1 rounded border workitem-card"
                                 role="button"
                                 tabindex="0"
                                 data-bs-toggle="modal"
                                 data-bs-target="#modalTarea-@task.Id"
                                 aria-label="Abrir tarea: @task.Title"
                                 onkeydown="if(event.key==='Enter'||event.key===' ')this.click()">
                                @task.Title
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Cuadrante 2: Importante + No urgente -->
            <div class="col-md-6">
                <div class="card border-primary h-100">
                    <div class="card-header bg-primary text-white fw-bold">
                        📅 Planifícalo
                        <small class="fw-normal ms-1">Importante + No urgente</small>
                    </div>
                    <div class="card-body p-2">
                        @foreach (var task in pendientes.Where(t => t.EisenhowerQuadrant == EisenhowerQuadrant.Schedule))
                        {
                            <div class="p-2 mb-1 rounded border workitem-card"
                                 role="button"
                                 tabindex="0"
                                 data-bs-toggle="modal"
                                 data-bs-target="#modalTarea-@task.Id"
                                 aria-label="Abrir tarea: @task.Title"
                                 onkeydown="if(event.key==='Enter'||event.key===' ')this.click()">
                                @task.Title
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Cuadrante 3: No importante + Urgente -->
            <div class="col-md-6">
                <div class="card border-warning h-100">
                    <div class="card-header bg-warning text-dark fw-bold">
                        👥 Delégalo
                        <small class="fw-normal ms-1">No importante + Urgente</small>
                    </div>
                    <div class="card-body p-2">
                        @foreach (var task in pendientes.Where(t => t.EisenhowerQuadrant == EisenhowerQuadrant.Delegate))
                        {
                            <div class="p-2 mb-1 rounded border workitem-card"
                                 role="button"
                                 tabindex="0"
                                 data-bs-toggle="modal"
                                 data-bs-target="#modalTarea-@task.Id"
                                 aria-label="Abrir tarea: @task.Title"
                                 onkeydown="if(event.key==='Enter'||event.key===' ')this.click()">
                                @task.Title
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Cuadrante 4: No importante + No urgente -->
            <div class="col-md-6">
                <div class="card border-secondary h-100">
                    <div class="card-header bg-secondary text-white fw-bold">
                        🗑️ Elimínalo
                        <small class="fw-normal ms-1">No importante + No urgente</small>
                    </div>
                    <div class="card-body p-2">
                        @foreach (var task in pendientes.Where(t => t.EisenhowerQuadrant == EisenhowerQuadrant.Delete))
                        {
                            <div class="p-2 mb-1 rounded border workitem-card"
                                 role="button"
                                 tabindex="0"
                                 data-bs-toggle="modal"
                                 data-bs-target="#modalTarea-@task.Id"
                                 aria-label="Abrir tarea: @task.Title"
                                 onkeydown="if(event.key==='Enter'||event.key===' ')this.click()">
                                @task.Title
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>

        <p class="text-muted small mt-3">
            Las tareas sin prioridad Alta y sin fecha límite aparecen en "Elimínalo".
            Asigna prioridad y fecha para clasificarlas correctamente.
        </p>
    </div>
</div>

<!-- Buscador de tareas -->
<div class="d-flex gap-2 mb-3">
    <div class="flex-grow-1">
        <label for="filtroTitulo" class="visually-hidden">Buscar tarea</label>
        <input type="search" id="filtroTitulo" class="form-control form-control-sm"
               placeholder="Buscar tarea..." />
    </div>
    <div>
        <label for="filtroPrioridad" class="visually-hidden">Filtrar por prioridad</label>
        <select id="filtroPrioridad" class="form-select form-select-sm">
            <option value="">Toda prioridad</option>
            <option value="Alta">Alta</option>
            <option value="Media">Media</option>
            <option value="Baja">Baja</option>
            <option value="none">Sin prioridad</option>
        </select>
    </div>
    <div>
        <label for="filtroEstado" class="visually-hidden">Filtrar por estado</label>
        <select id="filtroEstado" class="form-select form-select-sm">
            <option value="">Todo estado</option>
            <option value="pendiente">Pendiente</option>
            <option value="completada">Completada</option>
        </select>
    </div>
</div>

<!-- Cabecera de tareas -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h5 mb-0">Tareas</h2>
    <button class="btn btn-primary btn-sm"
            data-bs-toggle="modal" data-bs-target="#modalCrearTarea">
        + Nueva tarea
    </button>
</div>

<!-- Sin tareas -->
@if (!Model.Tasks.Any())
{
    <p class="text-muted text-center py-4">
        No hay tareas en este proyecto todavía.
    </p>
}
else
{
    <!-- Tareas pendientes -->
    @if (pendientes.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3 mb-4">
            @foreach (var task in pendientes)
            {
                <div class="col task-card"
                     data-titulo="@task.Title.ToLower()"
                     data-prioridad="@(task.Priority?.ToString() ?? "none")"
                     data-estado="pendiente">
                    <div class="card h-100 shadow-sm workitem-card"
                         role="button"
                         tabindex="0"
                         data-bs-toggle="modal"
                         data-bs-target="#modalTarea-@task.Id"
                         aria-label="Abrir tarea: @task.Title"
                         onkeydown="if(event.key==='Enter'||event.key===' ')this.click()">
                        <div class="card-body d-flex align-items-center gap-2">
                            <span class="text-muted fs-5">☐</span>
                            <span>@task.Title</span>
                            @if (task.Priority.HasValue)
                            {
                                <span class="badge mt-1 @(task.Priority switch
                                                        {
                                                            Priority.Alta => "bg-danger",
                                                            Priority.Media => "bg-warning text-dark",
                                                            _ => "bg-secondary"
                                                        })" style="width: fit-content;">
                                    @task.Priority
                                </span>
                            }
                            @if (task.DueDate.HasValue)
                            {
                                var vencida = task.DueDate.Value < DateOnly.FromDateTime(DateTime.Today);
                                <span class="badge mt-1 @(vencida ? "bg-danger" :
                                                        task.IsUrgent ? "bg-warning text-dark" :
                                                        task.IsOneWeekToDueDate ? "bg-info text-dark" :
                                                        "bg-light text-dark border")"
                                      style="width: fit-content;">
                                    @(vencida ? "⚠️ " : "📅 ")@task.DueDate.Value.ToString("dd/MM/yyyy")
                                </span>
                            }
                            <span class="text-muted">@task.Description</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Tareas completadas (colapsables) -->
    @if (completadas.Any())
    {
        <div class="mb-3">
            <button class="btn btn-sm btn-link text-muted p-0 text-decoration-none"
                    data-bs-toggle="collapse"
                    data-bs-target="#completadas">
                ▸ Completadas (@completadas.Count)
            </button>
            <div class="collapse mt-2" id="completadas">
                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
                    @foreach (var task in completadas)
                    {
                        <div class="col task-card"
                             data-titulo="@task.Title.ToLower()"
                             data-prioridad="@(task.Priority?.ToString() ?? "none")"
                             data-estado="completada">
                            <div class="card h-100 shadow-sm workitem-card opacity-75"
                                 role="button"
                                 tabindex="0"
                                 data-bs-toggle="modal"
                                 data-bs-target="#modalTarea-@task.Id"
                                 aria-label="Abrir tarea: @task.Title"
                                 onkeydown="if(event.key==='Enter'||event.key===' ')this.click()">
                                <div class="card-body d-flex align-items-center gap-2">
                                    <span class="text-success-emphasis" aria-hidden="true">✓</span>
                                    <span class="text-decoration-line-through text-muted">
                                        @task.Title
                                        @if (task.Priority.HasValue)
                                        {
                                            <span class="badge mt-1 @(task.Priority switch
                                                                    {
                                                                        Priority.Alta => "bg-danger",
                                                                        Priority.Media => "bg-warning text-dark",
                                                                        _ => "bg-secondary"
                                                                    })" style="width: fit-content;">
                                                @task.Priority
                                            </span>
                                        }
                                        @if (task.DueDate.HasValue)
                                        {
                                            var vencida = task.DueDate.Value < DateOnly.FromDateTime(DateTime.Today);
                                            <span class="badge mt-1 @(vencida ? "bg-danger" :
                                                                    task.IsUrgent ? "bg-warning text-dark" :
                                                                    task.IsOneWeekToDueDate ? "bg-info text-dark" :
                                                                    "bg-light text-dark border")"
                                                  style="width: fit-content;">
                                                @(vencida ? "⚠️ " : "📅 ")@task.DueDate.Value.ToString("dd/MM/yyyy")
                                            </span>
                                        }
                                    </span>
                                    <span class="text-muted">@task.Description.</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}

<!-- ── Modal de cada tarea ──────────────────────────────────────────────── -->
@foreach (var task in Model.Tasks)
{
    <div class="modal fade" id="modalTarea-@task.Id" tabindex="-1"
         aria-labelledby="modalTareaLabel-@task.Id" aria-modal="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title h5" id="modalTareaLabel-@task.Id">@task.Title</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"
                            aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-3">
                        <span class="badge @(task.IsCompleted ? "bg-success" : "bg-warning text-dark")">
                            @(task.IsCompleted ? "Completada" : "Pendiente")
                        </span>
                    </p>
                    <hr />
                    
                    <!-- Formulario de edición -->
                    <form asp-controller="WorkItems" asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="projectId" value="@Model.Id" />
                        <input type="hidden" name="Id" value="@task.Id" />
                        <div class="mb-3">
                            <label for="titulo-@task.Id" class="form-label">Título</label>
                            <input id="titulo-@task.Id" name="Title" class="form-control"
                                   value="@task.Title" required maxlength="200" />
                        </div>
                        <div class="mb-3">
                            <label for="descripcion-@task.Id" class="form-label">Descripción</label>
                            <textarea id="descripcion-@task.Id" name="Description"
                                      class="form-control" rows="3">@task.Description</textarea>
                        </div>
                        <div class="mb-3">
                            <label for="priority-@task.Id" class="form-label">Prioridad</label>
                            <select id="priority-@task.Id" name="Priority" class="form-select">
                                <option value="">Sin prioridad</option>
                                <option value="Baja">Baja</option>
                                <option value="Media">Media</option>
                                <option value="Alta">Alta</option>
                            </select>
                        </div>
                        <script>
                            document.getElementById('priority-@task.Id').value = '@(task.Priority?.ToString() ?? "")';
                        </script>
                        <div class="mb-3">
                            <label for="duedate-@task.Id" class="form-label">Fecha límite</label>
                            <input id="duedate-@task.Id" name="DueDate" type="date"
                                   class="form-control" />
                        </div>
                        <script>
                            @if (task.DueDate.HasValue)
                            {
                                <text>
                                document.getElementById('duedate-@task.Id').value = '@task.DueDate.Value.ToString("yyyy-MM-dd")';
                                </text>
                            }
                        </script>
                        <button type="submit" class="btn btn-sm btn-primary">
                            Guardar cambios
                        </button>
                    </form>
                </div>
                <div class="modal-footer justify-content-between">
                    <!-- Toggle completada -->
                    <form asp-controller="WorkItems" asp-action="ToggleCompleted" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@task.Id"/>
                        <input type="hidden" name="projectId" value="@Model.Id"/>
                        <button type="submit"
                                class="btn btn-sm @(task.IsCompleted ? "btn-outline-secondary" : "btn-success")">
                            @(task.IsCompleted ? "Marcar pendiente" : "Marcar completada")
                        </button>
                    </form>
                    
                    <!-- Botón que abre modal de confirmación de borrado -->
                    <button class="btn btn-sm btn-outline-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#modalBorrarTarea-@task.Id"
                            data-bs-dismiss="modal">
                        Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal confirmación borrado de tarea -->
    <div class="modal fade" id="modalBorrarTarea-@task.Id" tabindex="-1"
         aria-labelledby="modalBorrarTareaLabel-@task.Id" aria-modal="true">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title h5" id="modalBorrarTareaLabel-@task.Id">¿Eliminar tarea?</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"
                            aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    ¿Seguro que quieres eliminar <strong>@task.Title</strong>?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm"
                            data-bs-dismiss="modal">Cancelar</button>
                    <form asp-controller="WorkItems" asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@task.Id" />
                        <input type="hidden" name="projectId" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal: Crear tarea -->
<div class="modal fade" id="modalCrearTarea" tabindex="-1"
     aria-labelledby="modalCrearTareaLabel" aria-modal="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="WorkItems" asp-action="Create"
                  asp-route-projectId="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h2 class="modal-title h5" id="modalCrearTareaLabel">Nueva tarea</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"
                            aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="nuevaTareaTitulo" class="form-label">
                            Título <span class="text-danger-emphasis" aria-hidden="true">*</span>
                            <span class="visually-hidden">(obligatorio)</span>
                        </label>
                        <input id="nuevaTareaTitulo" name="Title" class="form-control"
                               required maxlength="200" />
                    </div>
                    <div class="mb-3">
                        <label for="nuevaTareaDescripcion" class="form-label">Descripción</label>
                        <textarea id="nuevaTareaDescripcion" name="Description"
                                  class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="nuevaTareaPrioridad" class="form-label">Prioridad</label>
                        <select id="nuevaTareaPrioridad" name="Priority" class="form-select">
                            <option value="">Sin prioridad</option>
                            <option value="Baja">Baja</option>
                            <option value="Media">Media</option>
                            <option value="Alta">Alta</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="nuevaTareaFecha" class="form-label">Fecha límite</label>
                        <input id="nuevaTareaFecha" name="DueDate" type="date"
                               class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Crear tarea</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Editar proyecto -->
@if (!Model.IsInbox)
{
    <div class="modal fade" id="modalEditarProyecto" tabindex="-1"
         aria-labelledby="modalEditarProyectoLabel" aria-modal="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-controller="Projects" asp-action="Edit"
                      asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <div class="modal-header">
                        <h2 class="modal-title h5" id="modalEditarProyectoLabel">Editar proyecto</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"
                                aria-label="Cerrar"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="editarProyectoNombre" class="form-label">
                                Nombre <span class="text-danger" aria-hidden="true">*</span>
                                <span class="visually-hidden">(obligatorio)</span>
                            </label>
                            <input id="editarProyectoNombre" name="Name" class="form-control"
                                   value="@Model.Name" required maxlength="100" />
                        </div>
                        <div class="mb-3">
                            <label for="editarProyectoDescripcion" class="form-label">Descripción</label>
                            <textarea id="editarProyectoDescripcion" name="Description"
                                      class="form-control" rows="3">@Model.Description</textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Guardar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal: Confirmar borrado de proyecto -->
    <div class="modal fade" id="modalBorrarProyecto" tabindex="-1"
         aria-labelledby="modalBorrarProyectoLabel" aria-modal="true">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title h5" id="modalBorrarProyectoLabel">¿Eliminar proyecto?</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"
                            aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    ¿Seguro que quieres eliminar <strong>@Model.Name</strong> y todas sus tareas?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm"
                            data-bs-dismiss="modal">Cancelar</button>
                    <form asp-controller="Projects" asp-action="Delete"
                          asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        const inputs = ['filtroTitulo', 'filtroPrioridad', 'filtroEstado'];

        function aplicarFiltro() {
            const titulo = document.getElementById('filtroTitulo').value.toLowerCase();
            const prioridad = document.getElementById('filtroPrioridad').value;
            const estado = document.getElementById('filtroEstado').value;

            document.querySelectorAll('.task-card').forEach(card => {
                const coincideTitulo = !titulo || card.dataset.titulo.includes(titulo);
                const coincidePrioridad = !prioridad || card.dataset.prioridad === prioridad;
                const coincideEstado = !estado || card.dataset.estado === estado;

                card.style.display = (coincideTitulo && coincidePrioridad && coincideEstado)
                    ? '' : 'none';
            });
        }

        inputs.forEach(id => {
            document.getElementById(id).addEventListener('input', aplicarFiltro);
        });
    </script>
}
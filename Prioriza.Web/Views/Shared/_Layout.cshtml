<!DOCTYPE html>
<html lang="es" data-bs-theme="light">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Prioriza</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/Prioriza.Web.styles.css" asp-append-version="true"/>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand position-absolute start-50 translate-middle-x" asp-area="" asp-controller="Projects" asp-action="Index">Prioriza</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                    aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                <div class="d-flex align-items-center gap-1">
                    <span class="text-warning" aria-hidden="true">☀️</span>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="themeToggle"
                               role="switch" style="cursor: pointer;"
                               aria-label="Cambiar entre tema claro y oscuro" />
                    </div>
                    <span class="text-white" aria-hidden="true">🌙</span>
                </div>
            </div>
        </div>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - Prioriza - <a asp-area="" asp-controller="Home" asp-action="Privacy">Política de privacidad</a>
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    const html = document.documentElement;
    const toggle = document.getElementById('themeToggle');
    const saved = localStorage.getItem('theme') ?? 'light';
    html.setAttribute('data-bs-theme', saved);
    toggle.checked = saved === 'dark';

    toggle.addEventListener('change', () => {
        const next = toggle.checked ? 'dark' : 'light';
        html.setAttribute('data-bs-theme', next);
        localStorage.setItem('theme', next);
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
